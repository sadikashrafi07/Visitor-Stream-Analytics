# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
coverage/
.vite/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Environment files
# Keep real secrets out of git
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# -----------------------------------------------------------------------------
# Local-only files
# -----------------------------------------------------------------------------
*.local

# -----------------------------------------------------------------------------
# Cache / temp files
# -----------------------------------------------------------------------------
.cache/
.tmp/
temp/
tmp/
*.tmp

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# VS Code
# Ignore all workspace-local files by default,
# but keep shared project settings and recommendations
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Optional debug artifacts
# -----------------------------------------------------------------------------
*.seed
*.pid
*.pid.lock